const API_KEY = process.env.GEMINI_API_KEY!;

export async function generateRoadmap(input: {
  origin: string;
  destination: string;
  targetRole: string;
  timelineMonths: number;
  feasibility: string;
  warnings: string[];
}) {
  const prompt = `
You are a realistic career relocation advisor.
Create a personalized ranked action plan.
Be honest and practical.
Do not make guarantees.

Origin: ${input.origin}
Destination: ${input.destination}
Target Role: ${input.targetRole}
Timeline: ${input.timelineMonths} months
Feasibility: ${input.feasibility}
Warnings: ${input.warnings.join(", ") || "None"}

Return JSON format:
{
  "summary": "...",
  "steps": ["...", "...", "..."]
}
`;

  const res = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent?key=${API_KEY}`,
    {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{ parts: [{ text: prompt }] }]
      })
    }
  );

  const data = await res.json();

  const text = data.candidates?.[0]?.content?.parts?.[0]?.text || "{}";

  try {
    return JSON.parse(text);
  } catch {
    return {
      summary: "Generated roadmap available.",
      steps: [text]
    };
  }
} 
